# ─────────────────────────────────────────────
# Vrishabh / Vidur — Environment Variables
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# ── Required ──────────────────────────────────

# OpenAI — GPT-4o for agent reasoning, briefs, insights
OPENAI_API_KEY=sk-...

# NewsData.io — news sentiment pipeline (free tier: 200 req/day)
# https://newsdata.io
NEWSDATA_API_KEY=pub_...

# ── Optional (enriches data quality) ──────────

# IndianAPI — insider trades, bulk/block deals, BSE filings
# https://indianapi.in
INDIANAPI_KEY=

# ACLED — Armed Conflict Location & Event Data (geopolitical signals)
# Free registration at https://acleddata.com
ACLED_EMAIL=
ACLED_PASSWORD=

# MarketAux — additional news source
MARKETAUX_API_KEY=

# Angel One — live streaming quotes (yfinance is default)
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=

# ── Scheduler tuning (all optional) ───────────

# Market data refresh interval in seconds (default: 120 = 2 min)
VIDUR_MARKET_INTERVAL=120

# News refresh interval in seconds (default: 3600 = 1 hr)
VIDUR_NEWS_INTERVAL=3600

# Knowledge graph rebuild interval in seconds (default: 21600 = 6 hr)
VIDUR_GRAPH_INTERVAL=21600

# ─────────── Suvarn API(Optional. Falls back to simple TA engine.) ───────────

SUVARN_API_URL=

